{
  "compilerOptions": { 
    "composite": true,
    "isolatedModules": true,
    "libReplacement": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2023",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@repo/main/*": ["./main/src/*"],
      "@repo/utils/*": ["./utils/src/*"]
    }
  },
  "files": []
}
